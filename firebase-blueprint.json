{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user role and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["Admin", "User", "Viewer"], "description": "User access level" },
        "username": { "type": "string", "description": "Display name" }
      },
      "required": ["uid", "email", "role"]
    },
    "Camera": {
      "title": "Surveillance Device",
      "description": "Represents a camera or network device",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ip": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Online", "Offline"] },
        "lastUpdate": { "type": "string", "format": "date-time" },
        "wilaya": { "type": "string" },
        "failureReason": { "type": "string" }
      },
      "required": ["id", "name", "ip", "status", "wilaya"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles indexed by UID"
    },
    "/cameras/{cameraId}": {
      "schema": "Camera",
      "description": "Global list of surveillance devices"
    }
  }
}
